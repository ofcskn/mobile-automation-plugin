.data/*
fastlane/api_key.json
fastlane/google-play-api.json

# ── Runtime directories (user data — never commit) ──────────────────
# All generated app artifacts live under .msd/ at the project root.
# Screenshots are always generated, never committed
.msd/screenshots/*
!.msd/screenshots/.gitkeep
!.msd/screenshots/testapp/

# ── Memory (user-local registry — never commit) ──────────────────────
# .msd/memory/apps.json is created by /msd-init and contains real app paths.
# It must NEVER be committed. A .gitkeep preserves the directory on clone.
.msd/memory/apps.json

# ── Personal app data (each user's own apps — never commit) ─────────
# Every file below is created by /msd-init for the user's own apps.
# Only the testapp fixture and the .template.config.json are committed.
.msd/config/*.config.json
!.msd/config/.template.config.json
!.msd/config/testapp.config.json

.msd/versions/*
!.msd/versions/testapp/

.msd/metadata/*
!.msd/metadata/testapp/

.msd/locales/*
!.msd/locales/testapp/
